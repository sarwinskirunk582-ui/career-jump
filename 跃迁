<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>跃迁 Jump | AI 职场逻辑重构导师</title>
    <style>
        /* 莫兰迪色系：极简、温暖、专业 */
        body {
            margin: 0;
            padding: 0;
            background-color: #FDFBF7; /* 羊脂白背景 */
            font-family: 'PingFang SC', 'Helvetica Neue', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
        }

        /* 顶部标题区 */
        .header {
            text-align: center;
            margin-bottom: 25px;
            z-index: 10;
        }

        .header h1 {
            color: #3C3C3C;
            font-weight: 300;
            letter-spacing: 6px;
            margin: 0;
            font-size: 2.2rem;
        }

        .header p {
            color: #8E9775; /* 莫兰迪绿 */
            margin-top: 12px;
            font-size: 1rem;
            letter-spacing: 2px;
            opacity: 0.8;
        }

        /* 装饰用的呼吸球 */
        .orb {
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(167, 190, 174, 0.15) 0%, rgba(253, 251, 247, 0) 70%);
            border-radius: 50%;
            z-index: 1;
            animation: breathe 10s infinite ease-in-out;
        }

        @keyframes breathe {
            0%, 100% { transform: scale(1); opacity: 0.4; }
            50% { transform: scale(1.3); opacity: 0.7; }
        }

        /* 聊天容器 */
        #coze-chat-container {
            width: 92%;
            max-width: 1100px;
            height: 75vh;
            background: #FFFFFF;
            border-radius: 30px;
            box-shadow: 0 15px 50px rgba(142, 151, 117, 0.1);
            overflow: hidden;
            border: 1px solid rgba(142, 151, 117, 0.15);
            z-index: 5;
        }
    </style>
</head>
<body>

    <div class="orb"></div>

    <div class="header">
        <h1>跃迁 JUMP</h1>
        <p>让每一份经历，都具备穿透时代的逻辑力</p>
    </div>

    <div id="coze-chat-container"></div>

    <script src="https://lf-cdn.coze.cn/obj/unpkg/flow-platform/chat-sdk/1.0.1-beta.0/index.js"></script>
    <script>
        new CozeWebSDK.WebChatClient({
            config: {
                bot_id: '7625197442924806179', // 你的 Bot ID 已自动填入
            },
            componentProps: {
                title: '跃迁职场导师',
                layout: 'inline',
                container: document.getElementById('coze-chat-container'),
            },
            auth: {
                type: 'unauth', // 公开访问模式
            },
            ui: {
                base: {
                    icon: 'https://img.icons8.com/ios-filled/50/8E9775/sparkling-diamonds.png',
                    layout: 'standard',
                },
                footer: {
                    isShow: false,
                }
            }
        });
    </script>
</body>
</html>
